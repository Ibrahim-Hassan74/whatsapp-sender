@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>خريطة المنيا</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Leaflet -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <style>
            body {
                font-family: 'Segoe UI', Tahoma;
                background: linear-gradient(135deg, #eef2f3, #dfe9f3);
                margin: 0;
            }

            .container {
                max-width: 900px;
                margin: 40px auto;
            }

            .card {
                background: white;
                padding: 25px;
                border-radius: 15px;
                box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            }

            h2 {
                text-align: center;
                margin-bottom: 20px;
                color: #2c3e50;
            }

            .inputs {
                display: flex;
                gap: 10px;
                margin-bottom: 15px;
            }

            input {
                flex: 1;
                padding: 12px;
                border-radius: 8px;
                border: 1px solid #ddd;
                text-align: right;
                font-size: 14px;
            }

            button {
                width: 100%;
                padding: 12px;
                background: #3498db;
                border: none;
                color: white;
                font-size: 16px;
                border-radius: 8px;
                cursor: pointer;
                transition: 0.3s;
            }

                button:hover {
                    background: #2980b9;
                }

            #map {
                height: 450px;
                border-radius: 12px;
                margin-top: 15px;
            }
    </style>
</head>

<body>

    <div class="container">
        <div class="card">

            <h2>📍 خريطة + تحديد المسار</h2>

            <div class="inputs">
                <input id="start" placeholder="نقطة البداية (مثال: 27.18,31.18)">
                <input id="end" placeholder="نقطة الوصول (مثال: 27.20,31.25)">
            </div>

            <button onclick="drawRoute()">🚗 عرض المسار</button>

            <div id="map"></div>

        </div>
    </div>

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <script>
        var map = L.map('map').setView([27.18, 31.18], 12);

        L.tileLayer('https://{s}.tile.openstreetmap.fr/hot/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap'
        }).addTo(map);

        var routeLine, startMarker, endMarker;

        function parseLatLng(value) {
        var parts = value.split(",");
        return {
        lat: parseFloat(parts[0]),
        lng: parseFloat(parts[1])
        };
        }

        function drawRoute() {

        var start = parseLatLng(document.getElementById("start").value);
        var end = parseLatLng(document.getElementById("end").value);

        if (!start || !end || isNaN(start.lat) || isNaN(end.lat)) {
        alert("❌ اكتب الإحداثيات بشكل صحيح");
        return;
        }

        // حذف القديم
        if (routeLine) map.removeLayer(routeLine);
        if (startMarker) map.removeLayer(startMarker);
        if (endMarker) map.removeLayer(endMarker);

        // ماركر البداية والنهاية
        startMarker = L.marker([start.lat, start.lng]).addTo(map)
        .bindPopup("📍 نقطة البداية").openPopup();

        endMarker = L.marker([end.lat, end.lng]).addTo(map)
        .bindPopup("🏁 نقطة الوصول");

        var url = `https://router.project-osrm.org/route/v1/driving/${start.lng},${start.lat};${end.lng},${end.lat}?overview=full&geometries=geojson`;

        fetch(url)
        .then(res => res.json())
        .then(data => {

        var route = data.routes[0].geometry.coordinates;

        var latlngs = route.map(coord => [coord[1], coord[0]]);

        routeLine = L.polyline(latlngs, {
        color: '#3498db',
        weight: 6,
        opacity: 0.9
        }).addTo(map);

        map.fitBounds(routeLine.getBounds());
        })
        .catch(err => {
        console.error(err);
        alert("❌ حصل خطأ");
        });
        }
    </script>

</body>
</html>